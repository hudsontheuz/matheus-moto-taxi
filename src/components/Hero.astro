---
import CallButton from "./CallButton.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
---

<section
  id="inicio"
  class="relative overflow-hidden bg-[radial-gradient(circle_at_top_right,#7f1d1d,transparent_28%),linear-gradient(180deg,#111827_0%,#030712_100%)]"
>
  <div
    class="mx-auto grid max-w-6xl items-center gap-10 px-4 py-12 pb-24 lg:grid-cols-2 lg:px-6 lg:py-20"
  >
    <img
      src="/images/hero-entrega-moto.png"
      alt=""
      class="pointer-events-none absolute bottom-0 left-1/2 z-0 h-[85%] max-w-none -translate-x-1/2 object-contain opacity-45 lg:left-auto lg:right-[-180px] lg:h-full lg:translate-x-0 lg:opacity-90"
    />
    <div class="relative z-10">
      <p
        class="mb-4 inline-flex rounded-full bg-red-500/10 px-4 py-2 text-sm font-bold text-red-300 ring-1 ring-red-400/20"
      >
        Moto táxi em Pato Branco • Jardim Floresta
      </p>

      <h1
        class="max-w-3xl text-4xl font-black leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl"
      >
        Moto Táxi em Pato Branco com atendimento rápido e seguro
      </h1>

      <p class="mt-5 text-xl font-semibold text-red-300">
        Sua entrega com rapidez e segurança em Pato Branco e região.
      </p>

      <p class="mt-5 max-w-2xl text-base leading-8 text-slate-300 sm:text-lg">
        Atendimento com base no bairro Jardim Floresta, em Pato Branco. Faço
        transporte de passageiros, entregas rápidas e corridas agendadas para
        Pato Branco e cidades da região.
      </p>

      <div class="mt-8 grid gap-3 sm:flex">
        <CallButton label="Ligar agora" class="w-full text-lg sm:w-auto" />
        <WhatsAppButton label="Chamar no WhatsApp" class="w-full sm:w-auto" />
      </div>

      <div
        class="mt-6 flex flex-wrap gap-3 text-sm font-semibold text-slate-200"
      >
        <span
          class="rounded-full bg-white/10 px-4 py-2 shadow-sm ring-1 ring-white/10"
        >
          Pix e Dinheiro
        </span>
        <span
          class="rounded-full bg-white/10 px-4 py-2 shadow-sm ring-1 ring-white/10"
        >
          Segunda a sábado até às 18h
        </span>
      </div>
    </div>
  </div>
</section>
