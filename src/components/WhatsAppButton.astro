---
type Props = {
  label?: string;
  class?: string;
  iconClass?: string;
};

const message = encodeURIComponent(
  "Olá, Matheus! Vim pelo site e gostaria de combinar uma corrida ou entrega.",
);

const {
  label = "WhatsApp",
  class: className = "",
  iconClass = "",
} = Astro.props;
---

<a
  href={`https://wa.me/5546991073234?text=${message}`}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chamar Matheus Moto Táxi no WhatsApp"
  class={`inline-flex min-h-12 items-center justify-center rounded-full border border-green-600 bg-green-600 px-6 py-3 text-base font-bold text-white shadow-lg shadow-green-600/20 transition hover:border-green-700 hover:bg-green-700 hover:text-white focus:outline-none focus:ring-4 focus:ring-green-100 ${className}`}
>
  <span class={`inline-flex items-center ${iconClass}`}>
    <span aria-hidden="true" class="whatsapp-icon mr-2"></span>
    {label}
  </span>
</a>

<style>
  .whatsapp-icon {
    display: inline-block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    background-color: #ffffff !important;

    -webkit-mask-image: url("/images/whatsapp-button.svg");
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;

    mask-image: url("/images/whatsapp-button.svg");
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
  }

  @media (min-width: 768px) {
    .whatsapp-shake-desktop {
      animation: whatsapp-shake 3s ease-in-out infinite;
      transform-origin: center;
    }
  }

  @keyframes whatsapp-shake {
    0%,
    8%,
    100% {
      transform: rotate(0deg);
    }

    1% {
      transform: rotate(10deg);
    }

    2% {
      transform: rotate(-10deg);
    }

    3% {
      transform: rotate(8deg);
    }

    4% {
      transform: rotate(-8deg);
    }

    5% {
      transform: rotate(5deg);
    }

    6% {
      transform: rotate(-5deg);
    }

    7% {
      transform: rotate(0deg);
    }
  }
</style>
